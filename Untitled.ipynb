      "123\n"
     ]
    }
   ],
   "source": [
    "# Membuat list berisi data angka penjualan/nilai\n",
    "data = [15, 30, 20, 18, 40]\n",
    "\n",
    "# Inisialisasi variabel total dengan nilai awal 0\n",
    "total = 0\n",
    "\n",
    "# Melakukan perulangan untuk menjumlahkan setiap angka di dalam list data\n",
    "for i in data:\n",
    "    total += i\n",
    "# Menampilkan hasil total penjumlahan angka\n",
    "print(total)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "302ca5d0-8411-4c60-95e3-501846dde2fd",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "21.666666666666668\n"
     ]
    }
   ],
   "source": [
    "# Membuat fungsi untuk menghitung rata-rata (total jumlah dibagi banyak data)\n",
    "def rata_rata(data) :\n",
    "    return sum(data) / len(data)\n",
    "\n",
    "# Membuat list angka baru\n",
    "nilai = [15, 30, 20]\n",
    "# Memanggil fungsi rata_rata dan menampilkan hasilnya\n",
    "print(rata_rata(nilai))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "id": "9d4e7639-0c4a-4772-917a-919620b699dd",
   "metadata": {},
   "outputs": [
