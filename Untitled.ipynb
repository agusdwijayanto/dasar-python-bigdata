    "# Menyimpan nama toko ke dalam variabel teks (string)\n",
    "nama_toko = \"toko maju jaya\"\n",
    "# Menampilkan isi variabel nama_toko ke layar\n",
    "print(nama_toko)"
   ]
  },
  {
   "cell_type": "code",
